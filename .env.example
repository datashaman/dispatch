APP_NAME=Dispatch
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://dispatch.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ──────────────────────────────────────────────
# GitHub Webhooks
# ──────────────────────────────────────────────
# Generate a secret: openssl rand -hex 32
# Use the same value in your GitHub App or webhook settings
GITHUB_WEBHOOK_SECRET=
VERIFY_WEBHOOK_SIGNATURE=true
# The GitHub username of the bot (events from this user are ignored to prevent loops)
GITHUB_BOT_USERNAME=dispatch

# ──────────────────────────────────────────────
# GitHub App (optional — enables repo picker & auto-webhook setup)
# ──────────────────────────────────────────────
# Or create one automatically via Settings > GitHub App
GITHUB_APP_ID=
# Option 1: base64-encoded PEM (preferred for deployment)
#   base64 < your-app.private-key.pem | tr -d '\n'
GITHUB_APP_PRIVATE_KEY=
# Option 2: path to PEM file on disk (convenient for local dev)
GITHUB_APP_PRIVATE_KEY_PATH=

# ──────────────────────────────────────────────
# AI Providers
# ──────────────────────────────────────────────
# Set keys for providers you want to use. At least one is required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

VITE_APP_NAME="${APP_NAME}"
